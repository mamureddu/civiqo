  "query": "\n        INSERT INTO users (auth0_id, email, created_at, updated_at)\n        VALUES ($1, $2, NOW(), NOW())\n        ON CONFLICT (auth0_id)\n        DO UPDATE SET\n            email = EXCLUDED.email,\n            updated_at = NOW()\n        RETURNING id, auth0_id, email, created_at, updated_at\n        ",
